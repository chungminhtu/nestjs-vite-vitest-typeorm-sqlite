{
  "name": "application",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "concurrently \"npm run nest:dev\" \"npm run frontend:dev\"",
    "vitest": "vitest",
    "nest:start": "nest start",
    "nest:dev": "vite",
    "nest:dev:watch": "vite --mode development",
    "nest:build": "nest build",
    "nest:start:prod": "npm run nest:build && node ./dist/main.js",
    "nest:test": "vitest run",
    "nest:test:e2e": "vitest run --config vitest.config.e2e.ts",
    "nest:test:watch": "vitest",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:preview": "cd frontend && npm run preview",
    "dev:prod": "concurrently \"npm run nest:start:prod\" \"npm run frontend:preview\"",
    "start": "npm run dev",
    "e2e:backend": "npm run nest:test:e2e",
    "e2e:frontend:ui": "cd frontend && npm run test:e2e:ui",
    "e2e:frontend:no-ui": "cd frontend && npm run test:e2e:no-ui",
    "e2e:frontend:headed": "cd frontend && npm run test:e2e:headed",
    "e2e:frontend:debug": "cd frontend && npm run test:e2e:debug",
    "e2e:full:ui": "concurrently \"npm run nest:start\" \"npm run frontend:dev\" \"wait-on http://localhost:3000 && cd frontend && npm run test:e2e:ui\"",
    "e2e:full:no-ui": "concurrently \"npm run nest:start\" \"npm run frontend:dev\" \"wait-on http://localhost:3000 && cd frontend && npm run test:e2e:no-ui\"",
    "test:all": "npm run e2e:backend && npm run e2e:full:no-ui",
    "test:all:ui": "npm run e2e:backend && npm run e2e:full:ui",
    "test:runner": "node test-runner.js",
    "build": "npm run nest:build && npm run frontend:build",
    "install:all": "npm install && cd frontend && npm install",
    "clean": "rimraf node_modules dist && cd frontend && rimraf node_modules dist",
    "pnpm-install": "pnpm i",
    "clean-install": "npm i -g rimraf && rimraf node_modules && pnpm i && pnpm i"
  },
  "dependencies": {
    "@casl/ability": "^6.7.1",
    "@nestia/core": "^3.11.1",
    "@nestjs/common": "^10.4.1",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.1",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/typeorm": "^10.0.2",
    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "@paralleldrive/cuid2": "^2.2.2",
    "@swc/core": "^1.7.14",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compress-brotli": "^1.3.12",
    "cross-env": "^7.0.3",
    "csv-parse": "^5.5.6",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "json2csv": "6.0.0-alpha.2",
    "multer": "1.4.5-lts.1",
    "passport-local": "^1.0.0",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.20",
    "typeorm-extension": "^3.6.1",
    "typeorm-naming-strategies": "^4.1.0",
    "vite": "^5.4.1",
    "vite-plugin-node": "^3.1.0",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "2.0.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.4",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.4.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "@vitest/coverage-v8": "^2.0.5",
    "@vitest/ui": "^2.0.5",
    "autocannon": "^7.15.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "kill-port-process": "^3.2.1",
    "pid-from-port": "^1.1.3",
    "prettier": "^3.3.3",
    "ps-list": "^8.1.1",
    "redis-memory-server": "^0.11.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.4",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.2.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4",
    "wait-on": "^7.2.0"
  },
  "resolutions": {
    "vitest": "$vitest",
    "vite": "$vite",
    "eslint": "$eslint",
    "reflect-metadata": "$reflect-metadata",
    "better-sqlite3": "$better-sqlite3"
  },
  "pnpm": {
    "allowedDeprecatedVersions": {
      "superagent": "*",
      "@humanwhocodes/object-schema": "*",
      "@humanwhocodes/config-array": "*",
      "glob": "*",
      "rimraf": "*",
      "inflight": "*"
    },
    "ignoredBuiltDependencies": [
      "@nestjs/core",
      "bcrypt",
      "esbuild"
    ],
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "redis-memory-server",
      "sqlite3"
    ]
  }
}